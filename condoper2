    /* ── HERO ── */
    .hero {
      position: relative;
      height: 100svh;
      min-height: 500px;
      overflow: hidden;
      background: var(--dark);
    }

    .hero-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.85;
      display: block;
    }

    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to bottom,
        rgba(0,0,0,0.1) 0%,
        rgba(0,0,0,0.0) 40%,
        rgba(0,0,0,0.6) 100%
      );
    }

    .hero-content {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 2rem 1.5rem 2.5rem;
    }

    .hero-tag {
      display: inline-block;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--gold);
      border: 1px solid var(--gold);
      padding: 0.3rem 0.8rem;
      margin-bottom: 0.9rem;
    }

    .hero-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2rem, 7vw, 3.2rem);
      font-weight: 300;
      color: var(--white);
      line-height: 1.1;
      margin-bottom: 0.5rem;
      letter-spacing: -0.01em;
    }

    .hero-sub {
      font-size: 0.85rem;
      color: rgba(255,255,255,0.75);
      letter-spacing: 0.04em;
    }

    /* ── STATS BAR ── */
    .stats {
      background: var(--dark);
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      border-top: 1px solid rgba(201,169,110,0.3);
    }

    .stat {
      padding: 1.1rem 0.5rem;
      text-align: center;
      border-right: 1px solid rgba(255,255,255,0.08);
    }
    .stat:last-child { border-right: none; }

    .stat-value {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--gold);
      line-height: 1;
      margin-bottom: 0.3rem;
    }

    .stat-label {
      font-size: 0.6rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.45);
    }

    /* ── SECTION WRAPPER ── */
